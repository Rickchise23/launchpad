# Launch Pad — Environment Variables
# Copy this file to .env.local and fill in your values

# Canonical URL for Open Graph, sitemap, and metadata (set in Vercel for production)
# NEXT_PUBLIC_SITE_URL=https://uselaunchpad.dev

# Local dev without Clerk (never enable in production)
# LAUNCHPAD_AUTH_DISABLED=1

# Clerk (Auth) — required in production; create app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
# Optional explicit URLs (defaults work for most setups)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PRICE_ID=price_xxxxx

# Supabase (Launch Pad's own database)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
